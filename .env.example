# Mnemo — environment configuration
# All variables use the MNEMO_ prefix.

# --- Backend selection ----------------------------------------------------
MNEMO_STORE=chroma          # chroma | lance
MNEMO_PIPELINE=default      # default | llamaindex

# --- Embedding model ------------------------------------------------------
MNEMO_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Persistence ----------------------------------------------------------
MNEMO_PERSIST_DIR=./data

# --- Collections ----------------------------------------------------------
MNEMO_SPECS_COLLECTION=specs
MNEMO_BUGS_COLLECTION=bug_memory

# --- Source paths (read by the agentic ingestion CLIs) -------------------
# For the lab the asset folders live in the repo; in production these
# paths would point to your local mirror of Wiki/ADO exports.
MNEMO_SPECS_SOURCE_DIR=./assets/specs-source
MNEMO_BUGS_SOURCE_DIR=./assets/bugs-source

# --- Chunking -------------------------------------------------------------
MNEMO_CHUNK_SIZE=512
MNEMO_CHUNK_OVERLAP=64

# --- Retrieval ------------------------------------------------------------
MNEMO_TOP_K=5
